# Copy this file to .env before running docker compose.
# Do not commit real secrets.

POSTGRES_USER=guard_proxy
POSTGRES_PASSWORD=guard_proxy_dev_password
POSTGRES_DB=guard_proxy

JWT_SECRET_KEY=replace-this-with-a-random-secret
LOG_INGEST_SHARED_SECRET=replace-this-with-a-second-random-secret

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
VITE_API_BASE_URL=http://localhost:8080

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
ADMIN_FULL_NAME=Administrator
