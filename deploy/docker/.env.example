# Copy this file to .env before running docker compose.
# These example secrets are for local development only; replace them outside dev.

POSTGRES_USER=guard_proxy
POSTGRES_PASSWORD=guard_proxy_dev_password
POSTGRES_DB=guard_proxy

# The backend DATABASE_URL is built by docker-compose.yml from POSTGRES_*.

# Generate by `openssl rand -hex 32` or similar.
JWT_SECRET_KEY=guard-proxy-dev-jwt-secret-key-please-change
LOG_INGEST_SHARED_SECRET=guard-proxy-dev-log-ingest-shared-secret-please-change

# CORS_ORIGINS is a JSON array of origins that are allowed to make cross-origin requests 
# to the backend.

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Optional log-shipper tuning (defaults shown)
# SHIPPER_POLL_INTERVAL=1
# SHIPPER_BACKOFF_BASE=1
# SHIPPER_BACKOFF_MAX=30
# SHIPPER_REQUEST_TIMEOUT=5

# Local admin seed used by `make seed` and the benchmark lab.
# Should be changed after initial deployment. 
# ADMIN_EMAIL=admin@domain.com
# ADMIN_PASSWORD=GuardProxyDemo12345
# ADMIN_FULL_NAME=Administrator

# Ports HAProxy exposes to the host machine.
HAPROXY_HTTP_PORT=80
HAPROXY_HTTPS_PORT=443
